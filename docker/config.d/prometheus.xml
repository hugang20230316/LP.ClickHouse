<clickhouse>
    <prometheus>
        <!-- 以 Prometheus 格式暴露 ClickHouse 内部指标，供 Prometheus 抓取。 -->
        <endpoint>/metrics</endpoint>
        <port>9363</port>
        <metrics>true</metrics>
        <events>true</events>
        <asynchronous_metrics>true</asynchronous_metrics>
        <status_info>true</status_info>
    </prometheus>
</clickhouse>
